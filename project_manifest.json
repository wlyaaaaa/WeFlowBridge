{
  "schema": "weflowbridge.project_manifest.v1",
  "project": "WeFlowBridge",
  "local_path": "E:\\Projects\\Tools\\WeFlowBridge",
  "display_name": "微信聊天记录 AI 本地桥（WeChat History AI Bridge）",
  "repository": "wlyaaaaa/wechat-history-ai-bridge",
  "visibility": "public",
  "role": "provider_facing_adapter",
  "closeout_status": "ready_for_normal_maintenance",
  "closeout_audit": "docs/closeout_audit.md",
  "closeout_audited_on": "2026-07-07",
  "api_base_default": "http://127.0.0.1:5031",
  "weflow_baseline": {
    "version": "26.7.3",
    "product_version": "26.7.3.0",
    "verified_on": "2026-07-09",
    "requires_reprobe_after_version_change": true
  },
  "ai_contract_version": "v2",
  "integration_readiness": {
    "status": "ai_integration_1_0_ready",
    "release_tag": "v0.1.0",
    "completed_on": "2026-07-09",
    "definition": "public-safe machine contracts, CI/local verification, metadata-only probe mode, and versioned release anchor"
  },
  "machine_contracts": {
    "openapi": "docs/openapi.yaml",
    "ai_consumer_envelope_schema": "schemas/ai-consumer-envelope.v2.schema.json",
    "project_manifest_schema": "schemas/project-manifest.v1.schema.json",
    "ai_consumer_envelope_example": "docs/examples/ai_consumer_envelope.example.json"
  },
  "owns": [
    "public_safe_endpoint_notes",
    "health_checks",
    "watchdog_scripts",
    "ai_consumer_contract",
    "privacy_boundary"
  ],
  "does_not_own": [
    "raw_wechat_archive",
    "long_term_semantic_index",
    "relationship_analysis",
    "career_analysis",
    "personal_os_memory",
    "domain_decisions"
  ],
  "ai_calling_layer": "E:\\.agents\\plugins\\weflow-toolkit",
  "downstream_consumers": [
    "PersonalOS",
    "CareerCapital",
    "SocialCapital",
    "LifeCases"
  ],
  "privacy_forbidden": [
    "env_files",
    "weflow_token",
    "weflow_db_key",
    "raw_messages",
    "chatlab_exports",
    "conversation_screenshots",
    "contact_screenshots",
    "database_files",
    "wal_shm_files",
    "media_exports",
    "full_json_exports"
  ],
  "required_output_envelope": [
    "current_library",
    "library_evidence",
    "target_account",
    "target_conversation",
    "talker",
    "time_window",
    "retry_count",
    "message_count",
    "lastTimestamp_matches_newest",
    "content_scope"
  ],
  "ai_contract_v2_fields": [
    "request_method",
    "endpoint_family",
    "sync_watermark",
    "replyToMessageId",
    "quote",
    "media_manifest"
  ],
  "retrieval_rules": {
    "latest_messages": {
      "endpoint": "/api/v1/messages",
      "query": "talker=<talker>&limit=100",
      "methods": [
        "GET",
        "POST"
      ],
      "do_not_use_start_end": true,
      "sort_assumption": "createTime_desc",
      "newest_index": 0,
      "self_check": "sessions.lastTimestamp == messages[0].createTime",
      "retry_on_empty": true
    },
    "historical_messages": {
      "preferred_endpoint": "/api/v1/sessions/{id}/messages",
      "preferred_query": "since=<unix_seconds>&end=<unix_seconds>&limit=<n>&offset=<n>",
      "preferred_time_format": "unix_seconds",
      "format": "ChatLab Pull",
      "supports_incremental_sync": true,
      "bounded_window_required": true,
      "legacy_endpoint": "/api/v1/messages",
      "legacy_query": "talker=<talker>&start=<YYYYMMDD>&end=<YYYYMMDD>",
      "legacy_date_format": "YYYYMMDD",
      "retry_on_empty": true
    },
    "time": {
      "unix_timestamps": "UTC epoch seconds",
      "chinese_context_timezone": "UTC+8",
      "do_not_use_system_local_timezone_as_truth": true
    }
  },
  "safe_verification": {
    "contract_tests": "python -m unittest tests/test_project_contracts.py",
    "probe_script": "powershell -ExecutionPolicy Bypass -File E:\\Projects\\Tools\\WeFlowBridge\\probe-weflow.ps1",
    "metadata_only_probe": "powershell -ExecutionPolicy Bypass -File E:\\Projects\\Tools\\WeFlowBridge\\probe-weflow.ps1 -Json -Mode MetadataOnly -NoMessages",
    "public_boundary": "powershell -ExecutionPolicy Bypass -File E:\\Projects\\Tools\\WeFlowBridge\\tools\\test-public-boundary.ps1",
    "local_ci": "powershell -ExecutionPolicy Bypass -File E:\\Projects\\Tools\\WeFlowBridge\\tools\\test-ci-local.ps1",
    "powershell_parse_files": [
      "probe-weflow.ps1",
      "weflow_heartbeat.ps1",
      "weflow_boot_guardian.ps1",
      "enable-autologin.ps1"
    ]
  },
  "no_raw_wechat_data": true
}
