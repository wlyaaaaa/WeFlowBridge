# WeFlowBridge 配置模板 —— 复制为 .env 后填写真实值
# .env 已被 .gitignore 忽略，绝不会进入版本库。

# ── 调 API 真正需要的（只有这两个）──
WEFLOW_BASE_URL=http://127.0.0.1:5031
# token 在 WeFlow「设置 → API 服务」里查看/重新生成；若你的版本未开鉴权可留空
WEFLOW_TOKEN=__FILL_ME__

# ── 以下是 WeFlow 的内部密钥，调 API【用不到】，一般无需填写 ──
# 仅当你要自己写解密脚本时才需要；填了也只存在本地 .env，永不提交。
WEFLOW_DB_KEY=
WEFLOW_DB_ROOT=
WEFLOW_WXID=
WEFLOW_IMG_XOR=
WEFLOW_IMG_AES=
